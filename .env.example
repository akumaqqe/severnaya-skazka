# Основные настройки
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Основная база для разработки по ТЗ: MySQL
DB_ENGINE=mysql
DB_NAME=folk_school
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Пример для PostgreSQL
# DB_ENGINE=postgresql
# DB_NAME=folk_school
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Для Render и других платформ можно использовать строку подключения целиком
DATABASE_URL=
DB_CONN_MAX_AGE=60

# Временный локальный fallback только для быстрой проверки, не как основная dev-база:
# DB_ENGINE=sqlite
